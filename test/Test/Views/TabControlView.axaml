<UserControl
  x:Class="Test.Views.TabControlView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:AvaloniaFluentUI.Controls;assembly=AvaloniaFluentUI"
  xmlns:viewModel="clr-namespace:test.Test.ViewModels"
  d:DesignHeight="450"
  d:DesignWidth="800"
  x:DataType="viewModel:TabControlViewModel"
  mc:Ignorable="d">
  <StackPanel Orientation="Vertical" Spacing="10">
    <Button Click="Info" Content="Info"/>
    <Button Click="Success" Content="Success"/>
    <Button Click="Warning" Content="Warning"/>
    <Button Click="Error" Content="Error"/>

    <!--  NotificationCard  -->

    <WindowNotificationManager/>
    <NotificationCard/>

    <ProgressBar
      Name="ProgressBar"
      Maximum="100"
      Minimum="0"/>

    <RadioButton
      Click="ChangeValue"
      Content="Home"
      Theme="{StaticResource ChipsRadioButton}"/>
    <RadioButton Content="Game" Theme="{StaticResource ChipsRadioButton}"/>
    <RadioButton Content="Setting" Theme="{StaticResource ChipsRadioButton}"/>

    <ui:SearchTextBox Classes="Clear" SearchCommand="{Binding SearchCommand}"/>
    <TextBox Classes="Password" PasswordChar="*"/>

    <TabControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <!--  ItemsSource="{Binding ItemSource}"  -->

      <TabItem Header="Home"/>
      <TabItem Header="GitHub"/>
      <TabItem Header="Video"/>
      <TabItem Header="Music"/>
    </TabControl>

    <ui:SegmentedView
      Name="SegmentedView"
      VerticalAlignment="Stretch"
      SelectedIndex="0">
      <ui:SegmentedItem Content="Home"/>
      <ui:SegmentedItem Content="Music"/>
      <ui:SegmentedItem Content="Video"/>
      <ui:SegmentedItem Content="GitHub"/>
      <ui:SegmentedItem Content="Setting"/>

      <ui:SegmentedView.Content>
        <TextBlock
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          FontSize="24"
          Text="{Binding #SegmentedView.SelectedItem}"
          TextAlignment="Center"/>
      </ui:SegmentedView.Content>
    </ui:SegmentedView>

    <ui:SegmentedToggleView
      Name="SegmentedToggleView"
      VerticalAlignment="Stretch"
      Orientation="Vertical"
      SelectedIndex="0">
      <ui:SegmentedItem
        Width="256"
        HorizontalContentAlignment="Left"
        Content="Home"/>
      <ui:SegmentedItem HorizontalContentAlignment="Left" Content="Music"/>
      <ui:SegmentedItem HorizontalContentAlignment="Left" Content="Video"/>
      <ui:SegmentedItem HorizontalContentAlignment="Left" Content="GitHub"/>
      <ui:SegmentedItem HorizontalContentAlignment="Left" Content="Setting"/>
      <!-- <ui:SegmentedItem HorizontalAlignment="Stretch" /> -->
      <ui:SegmentedItem>
        <PathIcon Data="{StaticResource Home}"/>
      </ui:SegmentedItem>
      <ui:SegmentedItem>
        <PathIcon Data="{StaticResource Setting}"/>
      </ui:SegmentedItem>

      <ui:SegmentedToggleView.Content>
        <TextBlock
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          FontSize="24"
          Text="{Binding #SegmentedToggleView.SelectedItem}"
          TextAlignment="Center"/>
      </ui:SegmentedToggleView.Content>
    </ui:SegmentedToggleView>

    <ui:MultiSelectionComboBox ItemsSource="{Binding ItemSource}"/>
  </StackPanel>
</UserControl>
