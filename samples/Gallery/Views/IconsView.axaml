  <!--  Grid.Row="1"  -->
  <!--  Grid.Column="1"  -->
  <!--  Margin="10,0,0,0"  -->
  <!--  HorizontalAlignment="Left">  -->
  <!--  <TextBlock  -->
  <!--  Text="{Binding CurrentIconName}"  -->
  <!--  FontSize="18"  -->
  <!--  FontWeight="Bold" />  -->
  <!--  <Path  -->
  <!--  Width="64"  -->
  <!--  Height="64"  -->
  <!--  Margin="5,5,5,20"  -->
  <!--  HorizontalAlignment="Left"  -->
  <!--  Data="{Binding CurrentIconData, Mode=TwoWay}"  -->
  <!--  Fill="#000000"  -->
  <!--  Stretch="Uniform" />  -->
  <!--    -->
  <!--     <TextBlock Text="图标名字" FontSize="16" /> -->
  <!--     <TextBlock Text="{Binding CurrentIconName}" FontSize="12" /> -->
  <!--    -->
  <!--  <TextBlock  -->
  <!--  Margin="0,20,0,0"  -->
  <!--  Text="枚举成员"  -->
  <!--  FontSize="16" />  -->
  <!--     <TextBlock Text="{Binding CurrentItemEnumName}" FontSize="12" /> -->
  <!--   </StackPanel> -->
  <!-- </Grid> -->

</UserControl>
