<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:Gallery.Controls">

  <ControlTheme x:Key="{x:Type controls:ToolButton}" TargetType="controls:ToolButton">
    <Setter Property="Width" Value="40"/>
    <Setter Property="Height" Value="40"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="8"/>
    <Setter Property="IconBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.1"/>
      </Transitions>
    </Setter>

    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:ToolButton">
          <Border
            x:Name="PART_RootBorder"
            Padding="{TemplateBinding Padding}"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}">
            <PathIcon
              x:Name="PART_Icon"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Data="{TemplateBinding PathData}"
              Foreground="{TemplateBinding IconBrush}"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>

    <Style Selector="^:pointerover">
      <Setter Property="Background" Value="#1A000000"/>
    </Style>

    <Style Selector="^:pressed">
      <Setter Property="RenderTransform" Value="scale(0.95)"/>
      <Setter Property="Background" Value="#2E000000"/>
    </Style>

    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5"/>
      <Style Selector="^ /template/ PathIcon#PART_Icon">
        <Setter Property="Foreground" Value="Gray"/>
      </Style>
    </Style>
  </ControlTheme>
</ResourceDictionary>