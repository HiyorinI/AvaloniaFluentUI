<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:Gallery.Controls">

  <ControlTheme x:Key="{x:Type controls:AnimatedWrapPanel}" TargetType="controls:AnimatedWrapPanel">
    <Setter Property="AnimationDuration" Value="300"/>
    <Setter Property="ItemStaggerDelay" Value="30"/>
    <Setter Property="IsAnimationEnabled" Value="True"/>
  </ControlTheme>

</ResourceDictionary>
